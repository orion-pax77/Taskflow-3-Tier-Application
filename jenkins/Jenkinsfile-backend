pipeline {
    agent any
    environment {
        DOCKERHUB_USER    = 'orionpax77'
        BACKEND_IMAGE     = "${DOCKERHUB_USER}/taskflow-backend"
        IMAGE_TAG         = "${BUILD_NUMBER}"
        MANIFEST_REPO     = 'https://github.com/orion-pax77/Taskflow-3-Tier-Application.git'
    }
    stages {
        stage('📥 Checkout Code') {
            steps {
                checkout scm
                echo "✅ Code checked out — Build #${BUILD_NUMBER}"
            }
        }
        stage('📦 Install Dependencies') {
            steps {
                dir('Application-Code/backend') {
                    sh 'npm install'
                }
            }
        }
        stage('🔍 Security Scan (Trivy)') {
            steps {
                dir('Application-Code/backend') {
                    sh '''
                        trivy fs --exit-code 0 \
                          --severity HIGH,CRITICAL \
                          --no-progress .
                    '''
                }
            }
        }
        stage('🐳 Build Docker Image') {
            steps {
                dir('Application-Code/backend') {
                    sh "docker build -t ${BACKEND_IMAGE}:${IMAGE_TAG} ."
                    sh "docker tag ${BACKEND_IMAGE}:${IMAGE_TAG} ${BACKEND_IMAGE}:latest"
                }
            }
        }
        stage('🔐 Push to DockerHub') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh "echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin"
                    sh "docker push ${BACKEND_IMAGE}:${IMAGE_TAG}"
                    sh "docker push ${BACKEND_IMAGE}:latest"
                }
            }
        }
        stage('📝 Update K8s Manifest') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'github-token', usernameVariable: 'GH_USER', passwordVariable: 'GH_TOKEN')]) {
                    sh """
                        git config user.email "jenkins@taskflow.com"
                        git config user.name "Jenkins CI"
                        sed -i "s|image: orionpax77/taskflow-backend:.*|image: orionpax77/taskflow-backend:${IMAGE_TAG}|" k8s_manifests/backend/deploy.yaml
                        git add k8s_manifests/backend/deploy.yaml
                        git commit -m "CI: Update backend image to ${IMAGE_TAG}"
                        git push https://\${GH_TOKEN}@github.com/orion-pax77/3-tier-project.git HEAD:main
                    """
                }
            }
        }
    }                      
    post {
        success {
            echo "✅ Backend pipeline succeeded — Image: ${BACKEND_IMAGE}:${IMAGE_TAG}"
        }
        failure {
            echo "❌ Backend pipeline FAILED — Check logs above"
        }
        always {
            sh "docker rmi ${BACKEND_IMAGE}:${IMAGE_TAG} || true"
            sh "docker rmi ${BACKEND_IMAGE}:latest || true"
        }
    }
}
